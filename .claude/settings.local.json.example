{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": [
    "Personal overrides for this project. Copy to settings.local.json.",
    "Arrays (permissions.allow, permissions.deny) MERGE with shared settings.json.",
    "Scalars (model, env) OVERRIDE shared settings.json.",
    "Deny always wins: local allow CANNOT override shared deny.",
    "",
    "Common use cases:",
    "  permissions.allow: [\"Bash(docker *)\"]     - add docker permission",
    "  model: \"claude-haiku-4-5\"                  - use faster model for experiments",
    "  env: { \"GOPATH\": \"/custom/go\" }            - machine-specific paths",
    "  permissions.allow: [\"Bash(git push *)\"]    - allow push"
  ],
  "permissions": {
    "allow": [],
    "deny": []
  },
  "env": {}
}
