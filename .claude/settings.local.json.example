{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/config-schema.json",
  "_comment": [
    "Personal overrides — copy to settings.local.json (gitignored).",
    "Scalars override settings.json values; arrays merge; deny wins over allow.",
    "Common use cases:",
    "  - Add project-specific permissions (docker, kubectl, etc.)",
    "  - Set environment variables (GIT_STRIP_CO_AUTHOR, etc.)",
    "  - Override model for local development",
    "  - Configure worktree.sparsePaths for monorepo optimization"
  ],
  "_env_comment": [
    "CLAUDE_HANDOFF_VALIDATION_MODE  (IMP-01) warn|strict — strict blocks writes of invalid handoff JSON",
    "CLAUDE_VERDICT_VALIDATION_MODE  (IMP-02) warn|strict — strict forces VERDICT_JSON schema pass (falls back to regex otherwise)",
    "Both envs are independent. Default: warn on both. Set both to strict for full schema enforcement."
  ],
  "env": {
    "GIT_STRIP_CO_AUTHOR": "false",
    "_CLAUDE_HANDOFF_VALIDATION_MODE": "strict",
    "_CLAUDE_VERDICT_VALIDATION_MODE": "strict"
  },
  "permissions": {
    "allow": [],
    "deny": []
  },
  "_worktree_comment": "Uncomment for monorepos (100k+ files) to speed up code-reviewer worktree creation. Only checked-out paths will be visible to the reviewer agent.",
  "worktree": {
    "sparsePaths": ["internal/", "cmd/", "go.mod", "go.sum", "Makefile"]
  }
}
