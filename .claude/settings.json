{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "TodoWrite",
      "Bash(make *)",
      "Bash(go test *)",
      "Bash(go generate *)",
      "Bash(go list *)",
      "Bash(go build *)",
      "Bash(go fmt *)",
      "Bash(go vet *)",
      "Bash(go mod *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout -b *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(touch *)",
      "Bash(tree *)",
      "Edit(/.claude/skills/workflow-protocols/**)",
      "Edit(/.claude/skills/planner-rules/**)",
      "Edit(/.claude/skills/coder-rules/**)",
      "Edit(/.claude/skills/plan-review-rules/**)",
      "Edit(/.claude/skills/systematic-debugging/**)",
      "Bash(git worktree:*)",
      "Bash(npx markdownlint-cli:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod 0777 *)",
      "Bash(dd if=*)",
      "Bash(mkfs.*)",
      "Bash(truncate *)",
      "Read(.env)"
    ],
    "additionalDirectories": [
      "/tmp",
      "/Users/dmitriym/Desktop/claude-kit/.claude/workflow-state"
    ]
  },
  "model": "sonnet",
  "enabledMcpjsonServers": [
    "sequential-thinking",
    "context7",
    "tree_sitter"
  ],
  "hooks": {
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/validate-instructions.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/protect-files.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "You are a Go architecture import matrix enforcer.\n\nRULES (strict, zero exceptions):\n1. handler layer (internal/handler/) may import: service, controller, models. NEVER: repository\n2. service layer (internal/service/) may import: repository, models. NEVER: handler\n3. repository layer (internal/repository/) may import: models. NEVER: handler, service\n4. models layer (internal/models/) stdlib only. NEVER: any internal/ package\n\nAnalyze this tool call for import violations:\n\n$ARGUMENTS\n\nSTEPS:\n1. Extract file_path from tool_input to determine the layer (handler/service/repository/models)\n2. If file is not in one of the 4 layers, respond {\"permissionDecision\": \"allow\"}\n3. If file is a test file (*_test.go), respond {\"permissionDecision\": \"allow\"}\n4. Find import statements in tool_input.content (Write) or tool_input.new_string (Edit)\n5. If no import statements found, respond {\"permissionDecision\": \"allow\"}\n6. Check each internal/ import against the rules for that layer\n7. If violation found, respond {\"permissionDecision\": \"deny\", \"permissionDecisionReason\": \"Import violation: [layer] must not import [forbidden package]\"}\n8. If no violations, respond {\"permissionDecision\": \"allow\"}\n\nRespond with ONLY the JSON object, nothing else.",
            "if": "Write(internal/**/*.go)",
            "timeout": 30
          },
          {
            "type": "prompt",
            "prompt": "You are a Go architecture import matrix enforcer.\n\nRULES (strict, zero exceptions):\n1. handler layer (internal/handler/) may import: service, controller, models. NEVER: repository\n2. service layer (internal/service/) may import: repository, models. NEVER: handler\n3. repository layer (internal/repository/) may import: models. NEVER: handler, service\n4. models layer (internal/models/) stdlib only. NEVER: any internal/ package\n\nAnalyze this tool call for import violations:\n\n$ARGUMENTS\n\nSTEPS:\n1. Extract file_path from tool_input to determine the layer (handler/service/repository/models)\n2. If file is not in one of the 4 layers, respond {\"permissionDecision\": \"allow\"}\n3. If file is a test file (*_test.go), respond {\"permissionDecision\": \"allow\"}\n4. Find import statements in tool_input.content (Write) or tool_input.new_string (Edit)\n5. If no import statements found, respond {\"permissionDecision\": \"allow\"}\n6. Check each internal/ import against the rules for that layer\n7. If violation found, respond {\"permissionDecision\": \"deny\", \"permissionDecisionReason\": \"Import violation: [layer] must not import [forbidden package]\"}\n8. If no violations, respond {\"permissionDecision\": \"allow\"}\n\nRespond with ONLY the JSON object, nothing else.",
            "if": "Edit(internal/**/*.go)",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/check-artifact-size.sh",
            "if": "Write(.claude/**)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/block-dangerous-commands.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/pre-commit-build.sh",
            "if": "Bash(git commit*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/auto-fmt-go.sh",
            "if": "Write(**/*.go)"
          },
          {
            "type": "command",
            "command": ".claude/scripts/auto-fmt-go.sh",
            "if": "Edit(**/*.go)"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/yaml-lint.sh",
            "if": "Edit(.claude/**)"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/check-references.sh",
            "if": "Write(.claude/**)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/check-plan-drift.sh",
            "if": "Write(.claude/**)"
          },
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/check-plan-drift.sh",
            "if": "Edit(.claude/**)"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/save-progress-before-compact.sh"
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/save-progress-before-compact.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/verify-state-after-compact.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "code-researcher",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/track-task-lifecycle.sh"
          }
        ]
      },
      {
        "matcher": "plan-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/track-task-lifecycle.sh"
          },
          {
            "type": "command",
            "command": ".claude/scripts/inject-review-context.sh plan-reviewer"
          }
        ]
      },
      {
        "matcher": "code-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/track-task-lifecycle.sh"
          },
          {
            "type": "command",
            "command": ".claude/scripts/inject-review-context.sh code-reviewer"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "plan-reviewer|code-reviewer|verdict-recovery",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/save-review-checkpoint.sh",
            "blocking": true
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/prepare-worktree.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/enrich-context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/verify-phase-completion.sh"
          },
          {
            "type": "command",
            "command": ".claude/scripts/check-uncommitted.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/session-analytics.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/log-stop-failure.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/notify-user.sh"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/audit-config-change.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "sparsePaths": [
      ".claude/",
      "internal/",
      "cmd/",
      "go.mod",
      "go.sum",
      "Makefile",
      "CLAUDE.md"
    ]
  },
  "autoMemoryEnabled": true,
  "thinking": {
    "type": "adaptive"
  }
}
