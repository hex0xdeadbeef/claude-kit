    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod 0777 *)",
      "Bash(dd if=*)",
      "Bash(mkfs.*)",
      "Bash(truncate *)",
      "Read(.env)"
