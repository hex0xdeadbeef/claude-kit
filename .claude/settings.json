{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/config-schema.json",
  "autoMemoryEnabled": true,
  "model": "sonnet",
  "thinking": {
    "type": "adaptive"
  },
  "worktree": {
    "sparsePaths": [
      ".claude/",
      "internal/",
      "cmd/",
      "go.mod",
      "go.sum",
      "Makefile",
      "CLAUDE.md"
    ]
  },
  "enabledMcpjsonServers": [
    "sequential-thinking",
    "context7",
    "tree_sitter"
  ],
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "TodoWrite",
      "Bash(make *)",
      "Bash(go test *)",
      "Bash(go generate *)",
      "Bash(go list *)",
      "Bash(go build *)",
      "Bash(go fmt *)",
      "Bash(go vet *)",
      "Bash(go mod *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout -b *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(touch *)",
      "Bash(tree *)",
      "Bash(bd *)",
      "Edit(/.claude/skills/workflow-protocols/**)",
      "Edit(/.claude/skills/planner-rules/**)",
      "Bash(sort -k2)",
      "Bash(find /Users/dmitriym/Desktop/claude-kit/.claude/agents -type f \\\\\\( -name \"*.md\" -o -name \"*.sh\" -o -name \"*.json\" \\\\\\) -exec wc -l {} +)",
      "Bash(find /Users/dmitriym/Desktop/claude-kit/.claude/skills -type f \\\\\\( -name \"*.md\" -o -name \"*.sh\" \\\\\\) -exec wc -l {} +)",
      "Bash(find /Users/dmitriym/Desktop/claude-kit/.claude/docs -type f -exec wc -l {} +)",
      "Bash(find /Users/dmitriym/Desktop/claude-kit/.claude/prompts -type f -exec wc -l {} +)",
      "Bash(find /Users/dmitriym/Desktop/claude-kit/.claude/reports -type f -exec wc -l {} +)",
      "Bash(find /Users/dmitriym/Desktop/claude-kit/.claude/templates/git-hooks -type f -exec wc -l {} +)",
      "Bash(find /Users/dmitriym/Desktop/claude-kit/.claude/research -type f -exec wc -l {} +)",
      "Bash(find /Users/dmitriym/Desktop/claude-kit/.claude/archive -type f -exec wc -l {} +)",
      "Bash(find /Users/dmitriym/Desktop/claude-kit/.claude/agent-memory -type f -exec wc -l {} +)",
      "Bash(grep -rn \"mcp__memory\\\\|server-memory\\\\|memory\\\\.json\\\\|MCP Memory\" .claude/commands/ .claude/agents/ .claude/skills/ .claude/rules/ CLAUDE.md README.md .claude/PROJECT-KNOWLEDGE.md --include=*.md --include=*.json --include=*.sh)",
      "Bash(git check-ignore:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod 0777 *)",
      "Bash(dd if=*)",
      "Bash(mkfs.*)",
      "Bash(truncate *)",
      "Read(.env)"
    ]
  },
  "hooks": {
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/validate-instructions.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/protect-files.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/check-artifact-size.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/block-dangerous-commands.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/pre-commit-build.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/auto-fmt-go.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/yaml-lint.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/check-references.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/check-plan-drift.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/save-progress-before-compact.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/verify-state-after-compact.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "plan-reviewer|code-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/save-review-checkpoint.sh"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/prepare-worktree.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/enrich-context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/verify-phase-completion.sh"
          },
          {
            "type": "command",
            "command": ".claude/scripts/check-uncommitted.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/session-analytics.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/log-stop-failure.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/notify-user.sh"
          }
        ]
      }
    ]
  }
}
