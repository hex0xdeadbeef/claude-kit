{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "TodoWrite",
      "Bash(make *)",
      "Bash(go test *)",
      "Bash(go generate *)",
      "Bash(go list *)",
      "Bash(go build *)",
      "Bash(go fmt *)",
      "Bash(go vet *)",
      "Bash(go mod *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout -b *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(touch *)",
      "Bash(tree *)",
      "Edit(/.claude/skills/workflow-protocols/**)",
      "Edit(/.claude/skills/planner-rules/**)",
      "Edit(/.claude/skills/coder-rules/**)",
      "Edit(/.claude/skills/plan-review-rules/**)",
      "Edit(/.claude/skills/systematic-debugging/**)",
      "Bash(git worktree:*)",
      "Bash(npx markdownlint-cli:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod 0777 *)",
      "Bash(dd if=*)",
      "Bash(mkfs.*)",
      "Bash(truncate *)",
      "Read(.env)"
    ],
    "additionalDirectories": [
      "/tmp",
      "/Users/dmitriym/Desktop/claude-kit/.claude/workflow-state"
    ]
  },
  "model": "sonnet",
  "enabledMcpjsonServers": [
    "sequential-thinking",
    "context7",
    "tree_sitter"
  ],
  "hooks": {
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/validate-instructions.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/protect-files.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/check-artifact-size.sh",
            "if": "Write(.claude/**)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/block-dangerous-commands.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/pre-commit-build.sh",
            "if": "Bash(git commit*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/auto-fmt-go.sh",
            "if": "Write(**/*.go)"
          },
          {
            "type": "command",
            "command": ".claude/scripts/auto-fmt-go.sh",
            "if": "Edit(**/*.go)"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/yaml-lint.sh",
            "if": "Edit(.claude/**)"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/check-references.sh",
            "if": "Write(.claude/**)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/check-plan-drift.sh",
            "if": "Write(.claude/**)"
          },
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/check-plan-drift.sh",
            "if": "Edit(.claude/**)"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/save-progress-before-compact.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/verify-state-after-compact.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "code-researcher",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/track-task-lifecycle.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "plan-reviewer|code-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/save-review-checkpoint.sh"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/prepare-worktree.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/enrich-context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/agents/meta-agent/scripts/verify-phase-completion.sh"
          },
          {
            "type": "command",
            "command": ".claude/scripts/check-uncommitted.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/session-analytics.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/log-stop-failure.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/notify-user.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "sparsePaths": [
      ".claude/",
      "internal/",
      "cmd/",
      "go.mod",
      "go.sum",
      "Makefile",
      "CLAUDE.md"
    ]
  },
  "autoMemoryEnabled": true,
  "thinking": {
    "type": "adaptive"
  }
}
