# Export-ignore: files/dirs excluded from `git archive` tarballs (GitHub Releases)
# These are excluded from the release tarball delivered via install.sh

# Dev-only tooling
superpowers-main/                   export-ignore
install.sh                          export-ignore
.github/                            export-ignore
.gitattributes                      export-ignore

# Project-specific (regenerated by /project-researcher after install)
.claude/PROJECT-KNOWLEDGE.md        export-ignore

# Personal overrides (gitignored, never delivered)
.claude/settings.local.json         export-ignore

# Runtime-only dirs (created on first use, not delivered)
.claude/workflow-state/             export-ignore
.claude/prompts/                    export-ignore
.claude/docs/                       export-ignore
.claude/agent-memory/               export-ignore
.claude/archive/                    export-ignore

# OS and VCS noise
**/.DS_Store                        export-ignore
**/.gitkeep                         export-ignore
